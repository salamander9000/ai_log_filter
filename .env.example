# Corporate proxy configuration
# Copy this file to .env and fill in your proxy URL.
#
#   cp .env.example .env
#
# Used during:
#   - docker compose build  (pip install reaches pypi.org)
#   - ollama model pull      (downloads LLM from ollama.com)
#
# Leave empty or delete if no proxy is needed.

HTTP_PROXY=http://proxy.corp.example.com:8080
HTTPS_PROXY=http://proxy.corp.example.com:8080
NO_PROXY=localhost,127.0.0.1,opensearch,ollama
