# ==========================================================================
# Environment configuration
# ==========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#

# --- Corporate proxy (for pip install + Ollama model pull) ---
HTTP_PROXY=http://proxy.corp.example.com:8080
HTTPS_PROXY=http://proxy.corp.example.com:8080
NO_PROXY=localhost,127.0.0.1,opensearch,haproxy,redis

# --- Input mode ---
# INPUT_MODE=kafka   (default, consume from Kafka topic with mTLS)
# INPUT_MODE=redis   (syslog-ng/Filebeat -> Redis -> AI service)
# INPUT_MODE=file    (tail a log file, for demo mode)
INPUT_MODE=kafka

# --- Kafka connection (when INPUT_MODE=kafka) ---
KAFKA_BROKERS=kafka-broker-1:9093,kafka-broker-2:9093
KAFKA_TOPIC=logs
KAFKA_GROUP_ID=ai-log-filter
KAFKA_AUTO_OFFSET_RESET=latest
# Place mTLS certificates in certs/ directory (see certs/README.md)
# If private key is password-protected:
# KAFKA_SSL_KEY_PASSWORD=your_password
# If connecting via HA proxy (cert CN doesn't match proxy hostname):
KAFKA_SSL_ENDPOINT_ALGO=none

# --- Rate limiter (0 = unlimited) ---
# Set to limit how many events/sec Layer 1 processes.
# Excess messages are silently dropped from the Kafka consumer.
RATE_LIMIT_PER_SEC=0

# --- Ollama connection ---
# Single server:  http://host.docker.internal:11434
# Multi-server:   http://haproxy:11434 (via HAProxy load balancer)
OLLAMA_HOST=http://haproxy:11434

# --- LLM model (used by Layer 2 AI service) ---
LLM_MODEL=qwen2.5:0.5b
# Number of LLM worker threads (set to number of Ollama servers + 2)
LLM_WORKERS=12

# --- Layer 3 Ollama (can be different pool/server than Layer 2) ---
# L3_OLLAMA_HOST=http://haproxy:11435
L3_LLM_MODEL=qwen2.5:3b

# --- Layer 3: Production Elasticsearch connection ---
# Leave PROD_ES_HOST empty to disable ES correlation.
PROD_ES_HOST=https://elasticsearch.corp.example.com:9200
PROD_ES_USER=readonly_user
PROD_ES_PASS=your_password_here
PROD_ES_INDEX=logs-*
PROD_ES_VERIFY_CERTS=false

# --- Layer 3: Correlation settings ---
CORRELATION_BEFORE_SEC=20
CORRELATION_AFTER_SEC=30
# L3_DELAY_SEC=0

# --- Layer 3 toggle ---
L3_ENABLED=true
