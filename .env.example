# ==========================================================================
# Environment configuration
# ==========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#

# --- Corporate proxy (for pip install + Ollama model pull) ---
HTTP_PROXY=http://proxy.corp.example.com:8080
HTTPS_PROXY=http://proxy.corp.example.com:8080
NO_PROXY=localhost,127.0.0.1,opensearch,ollama,haproxy,redis

# --- LLM model (used by Layer 2 AI service) ---
LLM_MODEL=qwen2.5:3b
# Number of LLM worker threads (set to number of Ollama servers + 2)
LLM_WORKERS=2

# --- Layer 3 LLM model (can be different/larger than Layer 2) ---
L3_LLM_MODEL=qwen2.5:3b

# --- Layer 3: Production Elasticsearch connection ---
# Set these to connect Layer 3 to your production ES for contextual queries.
# Leave PROD_ES_HOST empty to disable ES correlation (Layer 3 still runs but
# without historical context).
PROD_ES_HOST=https://elasticsearch.corp.example.com:9200
PROD_ES_USER=readonly_user
PROD_ES_PASS=your_password_here
PROD_ES_INDEX=logs-*
PROD_ES_VERIFY_CERTS=false

# --- Layer 3: Correlation settings ---
CORRELATION_WINDOW_SEC=300

# --- Input mode ---
# INPUT_MODE=redis   (default, Filebeat/syslog-ng -> Redis -> AI service)
# INPUT_MODE=file    (tail a log file, for demo mode)
INPUT_MODE=redis

# --- Layer 3 toggle ---
L3_ENABLED=true
